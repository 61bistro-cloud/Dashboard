generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  ACCOUNTANT
  STAFF
}

// ───────── Multi-tenant: Business + per-user access ─────────

model Business {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique // url/cookie-safe, e.g. "61-bistro"
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  users               UserBusiness[]
  employees           Employee[]
  suppliers           Supplier[]
  fixedCostCategories FixedCostCategory[]
  bankAccounts        BankAccount[]
  txCategories        TransactionCategory[]
  payrolls            EmployeePayroll[]
  payrollExtras       PayrollExtra[]
  purchases           SupplierPurchase[]
  fixedCosts          FixedCost[]
  revenueOverrides    MonthlyRevenueOverride[]
  posBills            PosBill[]
  posBatches          PosImportBatch[]
  accountOpenings     AccountOpening[]
  bankTransactions    BankTransaction[]
}

// Which businesses a non-OWNER user can access. OWNER sees all businesses
// implicitly (no rows needed).
model UserBusiness {
  id         Int    @id @default(autoincrement())
  userId     String
  businessId Int

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  // Optional — Google-OAuth users have no password.
  passwordHash String?
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posBatches       PosImportBatch[]
  bankTransactions BankTransaction[]
  businesses       UserBusiness[]
}

// ───────── Fiscal calendar (ปีงบ Apr-Mar) — SHARED across businesses ─────────

model FiscalYear {
  id        Int           @id @default(autoincrement())
  yearBE    Int           @unique // 2569 = Apr 2026 – Mar 2027
  label     String // "2569 (เม.ย. 2026 – มี.ค. 2027)"
  months    FiscalMonth[]
  createdAt DateTime      @default(now())
}

model FiscalMonth {
  id            Int    @id @default(autoincrement())
  yearId        Int
  monthIndex    Int // 1-12 (1 = เม.ย., 12 = มี.ค.)
  calendarYear  Int // 2026 or 2027
  calendarMonth Int // 1-12
  label         String // "เม.ย."
  fullLabel     String // "เมษายน 2569"
  daysInMonth   Int

  year             FiscalYear               @relation(fields: [yearId], references: [id], onDelete: Cascade)
  payrolls         EmployeePayroll[]
  payrollExtras    PayrollExtra[]
  purchases        SupplierPurchase[]
  fixedCosts       FixedCost[]
  revenueOverrides MonthlyRevenueOverride[]
  bankTransactions BankTransaction[]
  accountOpenings  AccountOpening[]

  @@unique([yearId, monthIndex])
  @@index([calendarYear, calendarMonth])
}

// ───────── Payroll (พนักงาน + ค่าจ้างพิเศษ) ─────────

model Employee {
  id         Int     @id @default(autoincrement())
  businessId Int
  name       String // "Max (System Operator) 12:00-21:00"
  shortName  String? // "Max"
  shift      String? // "12:00-21:00"
  active     Boolean @default(true)
  sortOrder  Int     @default(0)

  business Business          @relation(fields: [businessId], references: [id])
  payrolls EmployeePayroll[]

  @@index([businessId])
}

model EmployeePayroll {
  id            Int   @id @default(autoincrement())
  businessId    Int
  employeeId    Int
  fiscalMonthId Int
  amount        Float
  // Per-month override of the displayed name. Lets the user change shift /
  // role for THIS month without affecting other months or the global Employee.
  nameOverride  String?

  business    Business    @relation(fields: [businessId], references: [id])
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fiscalMonth FiscalMonth @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)

  @@unique([employeeId, fiscalMonthId])
  @@index([businessId, fiscalMonthId])
}

enum PayrollExtraType {
  OT
  BONUS
  EXTRA
  SERVICE_CHARGE
}

model PayrollExtra {
  id            Int              @id @default(autoincrement())
  businessId    Int
  fiscalMonthId Int
  type          PayrollExtraType
  amount        Float

  business    Business    @relation(fields: [businessId], references: [id])
  fiscalMonth FiscalMonth @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)

  @@unique([businessId, fiscalMonthId, type])
  @@index([businessId, fiscalMonthId])
}

// ───────── Suppliers (Food/Bev/Pack) ─────────

enum SupplierCategory {
  FOOD
  BEVERAGE
  PACKAGING
}

model Supplier {
  id         Int              @id @default(autoincrement())
  businessId Int
  name       String
  category   SupplierCategory
  sortOrder  Int              @default(0)
  active     Boolean          @default(true)

  business  Business           @relation(fields: [businessId], references: [id])
  purchases SupplierPurchase[]

  @@unique([businessId, category, name])
  @@index([businessId])
}

model SupplierPurchase {
  id            Int   @id @default(autoincrement())
  businessId    Int
  supplierId    Int
  fiscalMonthId Int
  amount        Float
  // Per-month override of the displayed supplier name. Same semantics as
  // EmployeePayroll.nameOverride.
  nameOverride  String?

  business    Business    @relation(fields: [businessId], references: [id])
  supplier    Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  fiscalMonth FiscalMonth @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)

  @@unique([supplierId, fiscalMonthId])
  @@index([businessId, fiscalMonthId])
}

// ───────── Fixed Cost (เช่า/ไฟน้ำ/Sub/...) ─────────

model FixedCostCategory {
  id         Int     @id @default(autoincrement())
  businessId Int
  name       String
  icon       String?
  sortOrder  Int     @default(0)
  active     Boolean @default(true)

  business Business    @relation(fields: [businessId], references: [id])
  costs    FixedCost[]

  @@unique([businessId, name])
  @@index([businessId])
}

model FixedCost {
  id            Int   @id @default(autoincrement())
  businessId    Int
  categoryId    Int
  fiscalMonthId Int
  amount        Float

  business    Business          @relation(fields: [businessId], references: [id])
  category    FixedCostCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  fiscalMonth FiscalMonth       @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)

  @@unique([categoryId, fiscalMonthId])
  @@index([businessId, fiscalMonthId])
}

// ───────── Revenue Override (เมื่อ POS ยังไม่ครบ) ─────────

model MonthlyRevenueOverride {
  id            Int     @id @default(autoincrement())
  businessId    Int
  fiscalMonthId Int
  amount        Float
  note          String?

  business    Business    @relation(fields: [businessId], references: [id])
  fiscalMonth FiscalMonth @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)

  @@unique([businessId, fiscalMonthId])
}

// ───────── POS Bills (จาก Foodstory) ─────────

model PosBill {
  id          String // หมายเลขใบเสร็จ (Foodstory receipt ID) — unique per business
  businessId  Int
  paidAt      DateTime // วันที่+เวลาที่ชำระเงิน
  paymentDate String // "YYYY-MM-DD" — actual payment date (calendar)
  /// "YYYY-MM-DD" — business day (cutoff 04:00). A bill paid 2026-05-01 02:30
  /// counts as the 2026-04-30 business day. Use this for revenue grouping
  /// to match Foodstory dashboard.
  businessDate String @default("")
  posId        String?
  invoiceNo    String?

  // financials
  grossAmount     Float // ยอดก่อนลด
  itemDiscount    Float @default(0)
  billDiscount    Float @default(0)
  totalAmount     Float @default(0) // ยอดรวม (หลังลด)
  serviceCharge   Float @default(0)
  vatAmount       Float @default(0)
  voucherAmount   Float @default(0)
  voucherDiscount Float @default(0)
  roundingAmount  Float @default(0)
  shippingFee     Float @default(0)
  grandTotal      Float @default(0) // รวมสุทธิ (ที่ลูกค้าจ่าย)
  tip             Float @default(0)
  refund          Float @default(0)

  // derived
  totalDiscount Float @default(0) // sum of all discounts
  netAmount     Float @default(0) // 💰 ยอดสุทธิ (Net) — สำหรับคำนวณ revenue

  // categorization
  orderType     String? // Dine-In / Take Away / Delivery
  paymentType   String? // Cash / PromptPay / VISA / Bank Transfer / Line Man - Rabbit Linepay / ...
  paymentMethod String? // วิธีบันทึกรายการชำระ
  channel       String? // หน้าร้าน / LINE MAN เดลิเวอรี / Grab / Wokboy
  tableNo       String? // โต๊ะ
  customerCount Int?
  customerName  String?
  note          String?

  promotionType String?
  promotionCode String?

  openedBy String?
  closedBy String?
  branch   String?

  lineManAdjustDate String?
  lineManAdjustAmt  Float?  @default(0)

  // audit
  importedAt    DateTime        @default(now())
  importBatchId Int?
  importBatch   PosImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  business      Business        @relation(fields: [businessId], references: [id])

  // Composite PK: receipt id is only unique WITHIN a business — two Foodstory
  // accounts can emit the same receipt number.
  @@id([businessId, id])
  @@index([businessId, businessDate])
  @@index([businessId, paymentDate])
  @@index([paidAt])
  @@index([paymentType])
  @@index([channel])
}

model PosImportBatch {
  id           Int      @id @default(autoincrement())
  businessId   Int
  fileName     String
  rowsTotal    Int      @default(0)
  rowsInserted Int      @default(0)
  rowsUpdated  Int      @default(0)
  rowsSkipped  Int      @default(0)
  rowsErrored  Int      @default(0)
  errorSample  String? // first few error messages, joined
  createdAt    DateTime @default(now())

  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  business     Business @relation(fields: [businessId], references: [id])

  bills PosBill[]

  @@index([businessId])
}

// ───────── Bank & Reconciliation ─────────

model BankAccount {
  id         Int    @id @default(autoincrement())
  businessId Int
  code       String // "KBANK", "SCB", "CASH", "KBANK_CREDIT" — unique per business
  name       String
  // "BANK" = checking/savings, "CREDIT_CARD" = card (closing balance shown as
  // outstanding debt rather than asset).
  accountType String  @default("BANK")
  icon        String?
  color       String?
  sortOrder   Int     @default(0)
  active      Boolean @default(true)

  business     Business          @relation(fields: [businessId], references: [id])
  openings     AccountOpening[]
  transactions BankTransaction[]

  @@unique([businessId, code])
  @@index([businessId])
}

model AccountOpening {
  id            Int   @id @default(autoincrement())
  businessId    Int
  accountId     Int
  fiscalMonthId Int
  amount        Float

  business    Business    @relation(fields: [businessId], references: [id])
  account     BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  fiscalMonth FiscalMonth @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)

  @@unique([accountId, fiscalMonthId])
  @@index([businessId, fiscalMonthId])
}

enum CategoryKind {
  INCOME // รายรับ
  EXPENSE // รายจ่าย
  TRANSFER // โอน/ATM/ยกยอด — ไม่นับ P&L
}

model TransactionCategory {
  id         Int          @id @default(autoincrement())
  businessId Int
  name       String
  kind       CategoryKind
  sortOrder  Int          @default(0)
  active     Boolean      @default(true)
  // map to POS payment channel for reconciliation (e.g. "EDC" / "PROMPTPAY" / "CASH" / "GRAB" / "LINEMAN")
  posChannel String?

  business     Business          @relation(fields: [businessId], references: [id])
  transactions BankTransaction[]

  @@unique([businessId, name])
  @@index([businessId])
}

model BankTransaction {
  id            Int  @id @default(autoincrement())
  businessId    Int
  fiscalMonthId Int
  accountId     Int
  categoryId    Int?

  date        DateTime
  description String
  deposit     Float    @default(0)
  withdraw    Float    @default(0)
  channel     String? // K PLUS / SCB Mobile / EDC / Cash / ATM ...
  note        String?
  // Running balance shown on the statement after this row. Used to dedupe
  // re-imports of overlapping date ranges. Null for manual entries.
  balanceAfter Float?

  createdAt   DateTime @default(now())
  createdById String?

  business    Business             @relation(fields: [businessId], references: [id])
  account     BankAccount          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  fiscalMonth FiscalMonth          @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)
  category    TransactionCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy   User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([businessId, fiscalMonthId, accountId, date])
  @@index([categoryId])
}
