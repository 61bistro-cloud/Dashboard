generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  ACCOUNTANT
  STAFF
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  // Optional — Google-OAuth users have no password.
  passwordHash String?
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posBatches       PosImportBatch[]
  bankTransactions BankTransaction[]
}

// ───────── Fiscal calendar (ปีงบ Apr-Mar) ─────────

model FiscalYear {
  id        Int           @id @default(autoincrement())
  yearBE    Int           @unique // 2569 = Apr 2026 – Mar 2027
  label     String // "2569 (เม.ย. 2026 – มี.ค. 2027)"
  months    FiscalMonth[]
  createdAt DateTime      @default(now())
}

model FiscalMonth {
  id            Int    @id @default(autoincrement())
  yearId        Int
  monthIndex    Int // 1-12 (1 = เม.ย., 12 = มี.ค.)
  calendarYear  Int // 2026 or 2027
  calendarMonth Int // 1-12
  label         String // "เม.ย."
  fullLabel     String // "เมษายน 2569"
  daysInMonth   Int

  year             FiscalYear              @relation(fields: [yearId], references: [id], onDelete: Cascade)
  payrolls         EmployeePayroll[]
  payrollExtras    PayrollExtra[]
  purchases        SupplierPurchase[]
  fixedCosts       FixedCost[]
  revenueOverride  MonthlyRevenueOverride?
  bankTransactions BankTransaction[]
  accountOpenings  AccountOpening[]

  @@unique([yearId, monthIndex])
  @@index([calendarYear, calendarMonth])
}

// ───────── Payroll (พนักงาน + ค่าจ้างพิเศษ) ─────────

model Employee {
  id        Int     @id @default(autoincrement())
  name      String // "Max (System Operator) 12:00-21:00"
  shortName String? // "Max"
  shift     String? // "12:00-21:00"
  active    Boolean @default(true)
  sortOrder Int     @default(0)

  payrolls EmployeePayroll[]
}

model EmployeePayroll {
  id            Int   @id @default(autoincrement())
  employeeId    Int
  fiscalMonthId Int
  amount        Float
  // Per-month override of the displayed name. Lets the user change shift /
  // role for THIS month without affecting other months or the global Employee.
  nameOverride  String?

  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fiscalMonth FiscalMonth @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)

  @@unique([employeeId, fiscalMonthId])
}

enum PayrollExtraType {
  OT
  BONUS
  EXTRA
  SERVICE_CHARGE
}

model PayrollExtra {
  id            Int              @id @default(autoincrement())
  fiscalMonthId Int
  type          PayrollExtraType
  amount        Float

  fiscalMonth FiscalMonth @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)

  @@unique([fiscalMonthId, type])
}

// ───────── Suppliers (Food/Bev/Pack) ─────────

enum SupplierCategory {
  FOOD
  BEVERAGE
  PACKAGING
}

model Supplier {
  id        Int              @id @default(autoincrement())
  name      String
  category  SupplierCategory
  sortOrder Int              @default(0)
  active    Boolean          @default(true)

  purchases SupplierPurchase[]

  @@unique([category, name])
}

model SupplierPurchase {
  id            Int   @id @default(autoincrement())
  supplierId    Int
  fiscalMonthId Int
  amount        Float
  // Per-month override of the displayed supplier name. Same semantics as
  // EmployeePayroll.nameOverride.
  nameOverride  String?

  supplier    Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  fiscalMonth FiscalMonth @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)

  @@unique([supplierId, fiscalMonthId])
}

// ───────── Fixed Cost (เช่า/ไฟน้ำ/Sub/...) ─────────

model FixedCostCategory {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  icon      String?
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  costs FixedCost[]
}

model FixedCost {
  id            Int   @id @default(autoincrement())
  categoryId    Int
  fiscalMonthId Int
  amount        Float

  category    FixedCostCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  fiscalMonth FiscalMonth       @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)

  @@unique([categoryId, fiscalMonthId])
}

// ───────── Revenue Override (เมื่อ POS ยังไม่ครบ) ─────────

model MonthlyRevenueOverride {
  id            Int     @id @default(autoincrement())
  fiscalMonthId Int     @unique
  amount        Float
  note          String?

  fiscalMonth FiscalMonth @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)
}

// ───────── POS Bills (จาก Foodstory) ─────────

model PosBill {
  id          String   @id // หมายเลขใบเสร็จ (Foodstory receipt ID)
  paidAt      DateTime // วันที่+เวลาที่ชำระเงิน
  paymentDate String // "YYYY-MM-DD" — actual payment date (calendar)
  /// "YYYY-MM-DD" — business day (cutoff 04:00). A bill paid 2026-05-01 02:30
  /// counts as the 2026-04-30 business day. Use this for revenue grouping
  /// to match Foodstory dashboard.
  businessDate String @default("")
  posId        String?
  invoiceNo    String?

  // financials
  grossAmount     Float // ยอดก่อนลด
  itemDiscount    Float @default(0)
  billDiscount    Float @default(0)
  totalAmount     Float @default(0) // ยอดรวม (หลังลด)
  serviceCharge   Float @default(0)
  vatAmount       Float @default(0)
  voucherAmount   Float @default(0)
  voucherDiscount Float @default(0)
  roundingAmount  Float @default(0)
  shippingFee     Float @default(0)
  grandTotal      Float @default(0) // รวมสุทธิ (ที่ลูกค้าจ่าย)
  tip             Float @default(0)
  refund          Float @default(0)

  // derived
  totalDiscount Float @default(0) // sum of all discounts
  netAmount     Float @default(0) // 💰 ยอดสุทธิ (Net) — สำหรับคำนวณ revenue

  // categorization
  orderType     String? // Dine-In / Take Away / Delivery
  paymentType   String? // Cash / PromptPay / VISA / Bank Transfer / Line Man - Rabbit Linepay / ...
  paymentMethod String? // วิธีบันทึกรายการชำระ
  channel       String? // หน้าร้าน / LINE MAN เดลิเวอรี / Grab / Wokboy
  tableNo       String? // โต๊ะ
  customerCount Int?
  customerName  String?
  note          String?

  promotionType String?
  promotionCode String?

  openedBy String?
  closedBy String?
  branch   String?

  lineManAdjustDate String?
  lineManAdjustAmt  Float?  @default(0)

  // audit
  importedAt    DateTime        @default(now())
  importBatchId Int?
  importBatch   PosImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([paymentDate])
  @@index([businessDate])
  @@index([paidAt])
  @@index([paymentType])
  @@index([channel])
}

model PosImportBatch {
  id           Int      @id @default(autoincrement())
  fileName     String
  rowsTotal    Int      @default(0)
  rowsInserted Int      @default(0)
  rowsUpdated  Int      @default(0)
  rowsSkipped  Int      @default(0)
  rowsErrored  Int      @default(0)
  errorSample  String? // first few error messages, joined
  createdAt    DateTime @default(now())

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  bills PosBill[]
}

// ───────── Bank & Reconciliation ─────────

model BankAccount {
  id   Int    @id @default(autoincrement())
  code String @unique // "KBANK", "SCB", "CASH", "KBANK_CREDIT"
  name String
  // "BANK" = checking/savings, "CREDIT_CARD" = card (closing balance shown as
  // outstanding debt rather than asset).
  accountType String  @default("BANK")
  icon        String?
  color       String?
  sortOrder   Int     @default(0)
  active      Boolean @default(true)

  openings     AccountOpening[]
  transactions BankTransaction[]
}

model AccountOpening {
  id            Int   @id @default(autoincrement())
  accountId     Int
  fiscalMonthId Int
  amount        Float

  account     BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  fiscalMonth FiscalMonth @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)

  @@unique([accountId, fiscalMonthId])
}

enum CategoryKind {
  INCOME // รายรับ
  EXPENSE // รายจ่าย
  TRANSFER // โอน/ATM/ยกยอด — ไม่นับ P&L
}

model TransactionCategory {
  id         Int          @id @default(autoincrement())
  name       String       @unique
  kind       CategoryKind
  sortOrder  Int          @default(0)
  active     Boolean      @default(true)
  // map to POS payment channel for reconciliation (e.g. "EDC" / "PROMPTPAY" / "CASH" / "GRAB" / "LINEMAN")
  posChannel String?

  transactions BankTransaction[]
}

model BankTransaction {
  id            Int  @id @default(autoincrement())
  fiscalMonthId Int
  accountId     Int
  categoryId    Int?

  date        DateTime
  description String
  deposit     Float    @default(0)
  withdraw    Float    @default(0)
  channel     String? // K PLUS / SCB Mobile / EDC / Cash / ATM ...
  note        String?

  createdAt   DateTime @default(now())
  createdById String?

  account     BankAccount          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  fiscalMonth FiscalMonth          @relation(fields: [fiscalMonthId], references: [id], onDelete: Cascade)
  category    TransactionCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy   User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([fiscalMonthId, accountId, date])
  @@index([categoryId])
}
